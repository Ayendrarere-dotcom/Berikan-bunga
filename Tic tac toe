<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<title>Tic Tac Toe Cinta</title>
<style>
body{
    font-family: Arial, sans-serif;
    text-align:center;
    background: linear-gradient(pink, #ffdde1);
}

h1{
    margin-top:20px;
}

#board{
    display:grid;
    grid-template-columns:repeat(3,100px);
    grid-gap:5px;
    justify-content:center;
    margin-top:20px;
}

.cell{
    width:100px;
    height:100px;
    background:white;
    font-size:50px;
    display:flex;
    align-items:center;
    justify-content:center;
    cursor:pointer;
    border-radius:10px;
}

.cell:hover{
    background:#ffe6ea;
}

#status{
    margin-top:20px;
    font-size:20px;
}

button{
    margin-top:15px;
    padding:10px 20px;
    font-size:16px;
    border:none;
    border-radius:10px;
    background:#ff6fa1;
    color:white;
    cursor:pointer;
}
</style>
</head>
<body>

<h1>❤️ Tic Tac Toe Cinta 💐</h1>
<p>Player 1 = ❤️ | Player 2 = 💐</p>

<div id="board"></div>

<div id="status">Giliran ❤️</div>

<button onclick="resetGame()">Main Lagi</button>

<script>
let board = ["","","","","","","","",""];
let currentPlayer = "❤️";
let gameActive = true;

const winConditions = [
[0,1,2],[3,4,5],[6,7,8],
[0,3,6],[1,4,7],[2,5,8],
[0,4,8],[2,4,6]
];

const boardElement = document.getElementById("board");

function createBoard(){
boardElement.innerHTML="";
board.forEach((cell,index)=>{
let div=document.createElement("div");
div.classList.add("cell");
div.dataset.index=index;
div.innerText=cell;
div.addEventListener("click",cellClick);
boardElement.appendChild(div);
});
}

function cellClick(e){
let index=e.target.dataset.index;

if(board[index]!=="" || !gameActive) return;

board[index]=currentPlayer;
createBoard();
checkWinner();

currentPlayer=currentPlayer==="❤️"?"💐":"❤️";
document.getElementById("status").innerText="Giliran "+currentPlayer;
}

function checkWinner(){
for(let condition of winConditions){
let [a,b,c]=condition;

if(board[a] && board[a]===board[b] && board[a]===board[c]){
document.getElementById("status").innerText=currentPlayer+" menang! 💕";
gameActive=false;
return;
}
}

if(!board.includes("")){
document.getElementById("status").innerText="Seri! Cinta tetap menang ❤️";
gameActive=false;
}
}

function resetGame(){
board=["","","","","","","","",""];
currentPlayer="❤️";
gameActive=true;
document.getElementById("status").innerText="Giliran ❤️";
createBoard();
}

createBoard();
</script>

</body>
</html>
